<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CréditImmobilier.Components.AmortizationTable">
    <Border BackgroundColor="#1A2230" Stroke="#2B3950" StrokeThickness="1" Padding="10" StrokeShape="RoundRectangle 10">
        <VerticalStackLayout Spacing="8">
            <Label Text="Tableau d'amortissement"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#DCE7F7"/>

            <Grid ColumnDefinitions="70,105,105,105,105,120,130"
                  ColumnSpacing="8"
                  Padding="8"
                  BackgroundColor="#2B3F5C">
                <Label Text="Mois" FontAttributes="Bold" FontSize="12" TextColor="#EDF3FF"/>
                <Label Text="Mensualité" Grid.Column="1" FontAttributes="Bold" FontSize="12" TextColor="#EDF3FF"/>
                <Label Text="Capital" Grid.Column="2" FontAttributes="Bold" FontSize="12" TextColor="#EDF3FF"/>
                <Label Text="Intérêts" Grid.Column="3" FontAttributes="Bold" FontSize="12" TextColor="#EDF3FF"/>
                <Label Text="Assurance" Grid.Column="4" FontAttributes="Bold" FontSize="12" TextColor="#EDF3FF"/>
                <Label Text="Capital restant" Grid.Column="5" FontAttributes="Bold" FontSize="12" TextColor="#EDF3FF"/>
                <Label Text="Capital remboursé" Grid.Column="6" FontAttributes="Bold" FontSize="12" TextColor="#EDF3FF"/>
            </Grid>

            <CollectionView x:Name="AmortizationCollectionView"
                            SelectionMode="None"
                            HeightRequest="340"
                            BackgroundColor="#151E2B">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="70,105,105,105,105,120,130"
                              ColumnSpacing="8"
                              Padding="8"
                              BackgroundColor="{Binding RowBackground}">
                            <Label Text="{Binding Month, StringFormat='{0:D3}'}" FontSize="11" TextColor="#EAF1FF"/>
                            <Label Text="{Binding Payment, StringFormat='{0:F2} €'}" Grid.Column="1" FontSize="11" TextColor="#EAF1FF"/>
                            <Label Text="{Binding Principal, StringFormat='{0:F2} €'}" Grid.Column="2" FontSize="11" TextColor="#EAF1FF"/>
                            <Label Text="{Binding Interest, StringFormat='{0:F2} €'}" Grid.Column="3" FontSize="11" TextColor="#EAF1FF"/>
                            <Label Text="{Binding Insurance, StringFormat='{0:F2} €'}" Grid.Column="4" FontSize="11" TextColor="#EAF1FF"/>
                            <Label Text="{Binding RemainingBalance, StringFormat='{0:F2} €'}" Grid.Column="5" FontSize="11" TextColor="#EAF1FF"/>
                            <Label Text="{Binding RepaidCapital, StringFormat='{0:F2} €'}" Grid.Column="6" FontSize="11" TextColor="#EAF1FF"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Border>
</ContentView>
